    "reflect-metadata":   "^0.2.2",
    "rxjs":               "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli":        "^10.3.2",
    "@nestjs/testing":    "^10.3.8",
    "@types/bcryptjs":    "^2.4.6",
    "@types/jest":        "^29.5.12",
    "@types/node":        "^20.14.0",
    "@types/nodemailer":  "^6.4.15",
    "@types/passport-jwt":"^4.0.1",
    "jest":               "^29.7.0",
    "prisma":             "^5.15.0",
    "ts-jest":            "^29.1.5",
    "ts-node":            "^10.9.2",
    "typescript":         "^5.4.5"
  }
